{
    "name": "smtcPlugin",
    "uuid": "com.michikora.smtcplugin",
    "version": "v1.0.0",
    "author": "Michikora",
    "entry": "backend/plugin.cjs",
    "description": "System Media Transport Controls integration for Flexbar",
    "repo": "https://github.com/michikora/Flexbar-SMTC-Plugin",
    "sdk": {
        "version": "1.0.7"
    },
    "software": {
        "minimumVersion": "1.3.0"
    },
    "os": [
        {
            "platform": "windows",
            "minimumVersion": "10"
        }
    ],
    "device": [
        {
            "name": "flexbar",
            "version": "1.0.0"
        }
    ],
    "configPage": "",
    "keyLibrary": {
        "title": "$PluginName",
        "style": {
            "icon": "mdi mdi-music-box"
        },
        "children": [
          {
              "title": "$NowPlaying.Title",
              "tip": "$NowPlaying.Tip",
              "cid": "com.michikora.smtcplugin.nowplaying",
              "config": {
                  "keyType": "default",
                  "clickable": false,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-music-note",
                  "width": 600,
                  "bgColor": "#000000",
                  "fgColor": "#ffffff",
                  "fontSize": 24,
                  "font": "Arial",
                  "flags": ["disable-common"]
              },
              "data": {
                  "autoBgColor": true,
                  "autoProgressFillColor": true,
                  "autoTextColor": true,
                  "manualBgColor": "#000000",
                  "manualProgressFillColor": "#1DB954",
                  "manualProgressBgColor": "#404040",
                  "manualTextColor": "#FFFFFF",
                  "fontMain": "\"Segoe UI\", -apple-system, BlinkMacSystemFont, Roboto, Arial, \"Meiryo\", \"Microsoft YaHei\", \"PingFang SC\", sans-serif",
                  "fontTime": "\"Segoe UI\", -apple-system, BlinkMacSystemFont, Roboto, Arial, \"Meiryo\", \"Microsoft YaHei\", \"PingFang SC\", sans-serif"
              }
          },
          {
              "title": "$PlayPause.Title",
              "tip": "$PlayPause.Tip",
              "cid": "com.michikora.smtcplugin.playpause",
              "config": {
                  "keyType": "multiState",
                  "clickable": true,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-play-pause",
                  "width": 120,
                  "flags": ["disable-layout-sel", "disable-icon-sel", "disable-title-sel"],
                  "multiStyle": [
                      {
                          "icon": "mdi mdi-play-pause",
                          "bgColor": "#424242",
                          "fgColor": "#FFFFFF"
                      },
                      {
                          "icon": "mdi mdi-play",
                          "bgColor": "#1DB954",
                          "fgColor": "#FFFFFF"
                      },
                      {
                          "icon": "mdi mdi-pause",
                          "bgColor": "#F44336",
                          "fgColor": "#FFFFFF"
                      }
                  ]
              },
              "data": {}
          },
          {
              "title": "$Prev.Title",
              "tip": "$Prev.Tip",
              "cid": "com.michikora.smtcplugin.previous",
              "config": {
                  "keyType": "default",
                  "clickable": true,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-skip-previous",
                  "bgColor": "#424242",
                  "fgColor": "#FFFFFF",
                  "width": 60,
                  "flags": ["disable-layout-sel", "disable-icon-sel", "disable-title-sel"]
              },
              "data": {}
          },
          {
              "title": "$Next.Title",
              "tip": "$Next.Tip",
              "cid": "com.michikora.smtcplugin.next",
              "config": {
                  "keyType": "default",
                  "clickable": true,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-skip-next",
                  "bgColor": "#424242",
                  "fgColor": "#FFFFFF",
                  "width": 60,
                  "flags": ["disable-layout-sel", "disable-icon-sel", "disable-title-sel"]
              },
              "data": {}
          },
          {
              "title": "$Shuffle.Title",
              "tip": "$Shuffle.Tip",
              "cid": "com.michikora.smtcplugin.shuffle",
              "config": {
                  "keyType": "multiState",
                  "clickable": true,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-shuffle",
                  "width": 60,
                  "flags": ["disable-layout-sel", "disable-icon-sel", "disable-title-sel"],
                  "multiStyle": [
                      {
                          "icon": "mdi mdi-shuffle",
                          "bgColor": "#424242",
                          "fgColor": "#555555"
                      },
                      {
                          "icon": "mdi mdi-shuffle",
                          "bgColor": "#424242",
                          "fgColor": "#FFFFFF"
                      },
                      {
                          "icon": "mdi mdi-shuffle",
                          "bgColor": "#424242",
                          "fgColor": "#1DB954"
                      }
                  ]
              },
              "data": {}
          },
          {
              "title": "$Loop.Title",
              "tip": "$Loop.Tip",
              "cid": "com.michikora.smtcplugin.loop",
              "config": {
                  "keyType": "multiState",
                  "clickable": true,
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-repeat",
                  "width": 60,
                  "flags": ["disable-layout-sel", "disable-icon-sel", "disable-title-sel"],
                  "multiStyle": [
                      {
                          "icon": "mdi mdi-repeat",
                          "bgColor": "#424242",
                          "fgColor": "#555555"
                      },
                      {
                          "icon": "mdi mdi-repeat",
                          "bgColor": "#424242",
                          "fgColor": "#FFFFFF"
                      },
                      {
                          "icon": "mdi mdi-repeat",
                          "bgColor": "#424242",
                          "fgColor": "#1DB954"
                      },
                      {
                          "icon": "mdi mdi-repeat-once",
                          "bgColor": "#424242",
                          "fgColor": "#1DB954"
                      }
                  ]
              },
              "data": {}
          },
          {
              "title": "$Volume.Title",
              "tip": "$Volume.Tip",
              "cid": "com.michikora.smtcplugin.volume",
              "config": {
                  "keyType": "slider",
                  "platform": ["windows"]
              },
              "style": {
                  "icon": "mdi mdi-volume-high",
                  "bgColor": "#000000",
                  "width": 360,
                  "flags": ["disable-bg-styles", "disable-icon-sel", "disable-layout-sel", "disable-func", "disable-common"],
                  "slider": {
                      "color": "#FFFFFF",
                      "width": 260,
                      "format": "",
                      "min": 0,
                      "max": 100,
                      "decimals": 0
                  }
              },
              "data": {}
          }
        ]
    },
    "local": {
        "en": {
            "PluginName": "SMTC Monitor",
            "NowPlaying": {
                "Title": "Now Playing",
                "Tip": "Displays current track artwork, title, and progress.",
                "UI": {
                    "autoBgColor": "Auto Background Color",
                    "autoProgressFillColor": "Auto Progress Fill Color",
                    "autoTextColor": "Auto Text Color",
                    "manualBgColor": "Manual Background Color",
                    "manualProgressFillColor": "Manual Progress Fill Color",
                    "manualProgressBgColor": "Manual Progress Background Color",
                    "manualTextColor": "Manual Text Color",
                    "fontMain": "Main Text Font",
                    "fontTime": "Time Text Font"
                }
            },
            "PlayPause": {
                "Title": "Play / Pause",
                "Tip": "Toggle media playback"
            },
            "Prev": {
                "Title": "Previous Track",
                "Tip": "Skip to previous track"
            },
            "Next": {
                "Title": "Next Track",
                "Tip": "Skip to next track"
            },
            "Shuffle": {
                "Title": "Shuffle",
